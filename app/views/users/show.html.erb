<div>
  <h1 class="font-bold text-4xl"><%= render "header", user: @user %></h1>

  <h3 class="text-2xl">Recently Edited Images</h3>
  <%= render @user.recent_image_participations.map { |p| p.image } %>

  <% if authenticated? and @user.messageable_by? Current.user or @user.messages.any? %>
    <h3 class="text-2xl">Received Comments</h3>
  <% end %>
  <% if authenticated? and @user.messageable_by? Current.user %>
    <%= render "messages/form", message: Message.new(target: @user) %>
  <% end %>
  <%= render @user.recent_received_messages %>
</div>
