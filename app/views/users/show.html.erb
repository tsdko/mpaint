<div>
  <h1 class="font-bold text-4xl">
    <%= render "header", user: @user %>
    <% if authenticated? and @user == Current.user %>
      <%= form_with url: session_path, method: :delete, class: "inline text-[50%]" do |form| %>
        <%= form.submit "Sign out" %>
      <% end %>
    <% end %>
  </h1>

  <h3 class="text-2xl">Recently Edited Images</h3>
  <%= render @user.recent_image_participations.map { |p| p.image } %>

  <% if authenticated? and @user.messageable_by? Current.user or @user.received_messages.any? %>
    <h3 class="text-2xl">Received Comments</h3>
  <% end %>
  <% if authenticated? and @user.messageable_by? Current.user %>
    <%= render "messages/form", message: Message.new(target: @user) %>
  <% end %>
  <%= render @user.recent_received_messages %>
</div>
