<%# locals: (container_data: {}, canvas_data: {}) %>

<%= tag.div(
      id: "canvasContainer",
      class: "p-2 relative touch-pinch-zoom overflow-auto max-h-[70vh]",
      data: container_data,
  )  do %>
  <%= tag.canvas(
      id: "imageCanvas",
      class: "bg-checkerboard brightness-50",
      width: @image.width,
      height: @image.height,
      data: canvas_data,
   ) %>
<% end %>
